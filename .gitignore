# Secrets — NEVER commit
.env
.env.local

# Local runtime state — regenerated on each run
state/sessions/*/
!state/sessions/.gitkeep
sandbox/*.txt
.venv/
gateway/.venv/
gateway/*.db
gateway/usage.json

# Build / cache artifacts
**/__pycache__/
**/*.pyc
**/uv.lock
**/.pytest_cache/

# Editors
.vscode/
.idea/
.DS_Store
_README.md
usage.json
